# Copy to .env and fill in. The pipeline reads these via `set -a; source .env`
# in scripts/run_pipeline.sh. Variables already exported in your shell
# (e.g. via `source setup.sh`) are NOT overridden — only blank values in this
# file would clobber, which is why the secrets below are commented out.

# Hugging Face — strongly recommended. Without it, dataset downloads are
# rate-limited and very slow (Isotonic can take 10x longer).
# Skip if your setup.sh / shell already exports HF_TOKEN.
# HF_TOKEN=hf_xxx

# vLLM (OpenAI-compatible) endpoint. Set this if your vLLM server runs
# somewhere other than localhost:8000. Leave unset to skip ko_korean_petitions
# synth (everything else still runs, you just get fewer Korean records).
VLLM_BASE_URL=http://localhost:8000/v1
# Remote example:
# VLLM_BASE_URL=https://my-vllm.example.com/v1

# vLLM ignores the API key by default; set --api-key on the server to require one.
VLLM_API_KEY=EMPTY

# Model id served by vLLM (must match what you launched it with).
VLLM_MODEL=Qwen/Qwen3-235B-A22B-Instruct
