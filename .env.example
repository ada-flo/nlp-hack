# vLLM (OpenAI-compatible) endpoint. Copy to .env and edit.
# Same code path for local and remote — only the URL changes.

# Local vLLM (default):
VLLM_BASE_URL=http://localhost:8000/v1

# Remote vLLM example:
# VLLM_BASE_URL=https://my-vllm.example.com/v1

# vLLM ignores the API key by default; set --api-key on the server to require one.
VLLM_API_KEY=EMPTY

# Model id served by vLLM (must match what you launched it with).
VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct
