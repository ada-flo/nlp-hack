# Raw and intermediate datasets — do not commit.
data/raw/
data/raw_manual/
data/interim/

# Processed split JSONLs are large (~50K records) — regenerate via the
# pipeline. The trained tokenizer (spm.model) is small and stays committed.
data/processed/*.jsonl

# Model checkpoints
checkpoints/

# Bulky archives and tabular dumps.
*.zip
*.tar.gz
*.parquet
*.csv

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.env

# Local env file (commit .env.example, ignore .env)
.env

# Editor / OS
.DS_Store
.idea/
.vscode/
